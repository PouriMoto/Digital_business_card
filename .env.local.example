# این فایل را کپی کن به .env.local و مقادیر واقعی را بگذار.
# .env.local هرگز نباید commit شود (قانون ۵ Constitution: بدون Secret در Frontend/Repo).

# لینک Web App که از Apps Script Deploy گرفتی (به .../exec ختم می‌شود)
APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbx6JpEsBX0je5HfHKjEDV6VlCPSJfRL9z4BBwHYSP_60zbV6hgCgsxwhjBxQax2Ob33fQ/exec

# همان مقداری که در Script Properties به اسم API_KEY گذاشتی
APPS_SCRIPT_KEY=REPLACE_WITH_YOUR_SECRET

# آدرس عمومی سایت بعد از دیپلوی روی Vercel (برای ساخت لینک اشتراک‌گذاری و QR)
NEXT_PUBLIC_SITE_URL=https://v2card.vercel.app

# فاز بعد (GA4) — فعلاً خالی بگذار
NEXT_PUBLIC_GA4_ID=
